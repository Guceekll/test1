# workflow.py
from langgraph.graph import StateGraph, END
from .state import TroubleState
from .nodes import (
    generate_query, collect_info_qvics,
    evaluate_info, refine_info,
    generate_report, optimizer
)

def build_workflow():
    workflow = StateGraph(TroubleState)

    workflow.add_node("クエリ生成", generate_query)
    workflow.add_node("情報収集_QVICS", collect_info_qvics)
    workflow.add_node("情報評価", evaluate_info)
    workflow.add_node("情報精選", refine_info)
    workflow.add_node("回答生成", generate_report)
    workflow.add_node("回答評価", optimizer)

    workflow.set_entry_point("クエリ生成")

    workflow.add_edge("クエリ生成", "情報収集_QVICS")
    workflow.add_edge("情報収集_QVICS", "情報評価")

    workflow.add_conditional_edges("情報評価", {
        "情報精選": lambda s: "Good" in s.get("evaluate_info", ""),
        "クエリ生成": lambda s: "Bad" in s.get("evaluate_info", ""),
    })

    workflow.add_edge("情報精選", "回答生成")
    workflow.add_edge("回答生成", "回答評価")

    workflow.add_conditional_edges("回答評価", {
        END: lambda s: "Good" in s.get("optimizer_decision", ""),
        "クエリ生成": lambda s: "Bad" in s.get("optimizer_decision", ""),
    })

    return workflow.compile()
