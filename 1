"""Streamlit page for searching and displaying a single code entry by name."""
import streamlit as st
import time
from code_shared import (
    local_css, render_code_card, CSS_PATH,
    load_code_from_file, render_sidebar
)

# ==== Session State ====
def _init_state() -> None:
    """Initialize minimal session state for search."""
    st.session_state.setdefault("search_term", "")
    st.session_state.setdefault("search_mode", False)


def _submit_search() -> None:
    """Commit current input into search state and toggle search mode."""
    term = st.session_state.get("search_input", "").strip()
    st.session_state["search_term"] = term
    st.session_state["search_mode"] = bool(term)


# ==== Page Entrypoint ====
def main() -> None:
    """Render the search UI and display the first matching code entry."""
    _init_state()
    local_css(CSS_PATH)
    render_sidebar("sub")

    st.set_page_config(page_title="Search Code", layout="wide")
    st.title("🔍 Search Code")
    st.markdown("Search by name")

    # Search input + explicit button (supports Enter, blur, and click)
    c1, c2 = st.columns([3, 1], gap="small")
    with c1:
        st.text_input(
            "Enter code label",
            key="search_input",
            placeholder="e.g., TEL",
            label_visibility="collapsed",
            on_change=_submit_search,
        )
    with c2:
        if st.button("Search", use_container_width=True):
            _submit_search()

    # Reset search mode if the input becomes empty
    if not st.session_state.get("search_input", "").strip():
        st.session_state["search_term"] = ""
        st.session_state["search_mode"] = False

    # Load data and current timestamp once per render
    code = st.session_state.get("code") or load_code_from_file()
    current_time = int(time.time())

    # Apply case-insensitive substring match and render the first hit
    if st.session_state["search_mode"] and st.session_state["search_term"]:
        term = st.session_state["search_term"].lower()
        matching = {k: v for k, v in code.items() if term in k.lower()}  # fuzzy match
        if matching:
            label, code_data = list(matching.items())[0]
            render_code_card(label, code_data, current_time, full_width=True)
        else:
            st.info("No code found with that label.")

    time.sleep(1)
    st.rerun()


if __name__ == "__main__":
    main()
