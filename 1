"""Utility module for generating and validating Base32 secrets."""
import base64
import re


def is_valid_base32(text: str) -> bool:
    """Return True if `text` is a decodable Base32 string (padding tolerated)."""
    try:
        t = re.sub(r"\s+", "", text)
        base64.b32decode(t + "=" * ((8 - len(t) % 8) % 8))
        return True
    except Exception:
        return False


def normalize_base32(text: str) -> str:
    """Uppercase & strip spaces only. Do NOT change the bytes."""
    return re.sub(r"\s+", "", text).upper()


def as_base32_secret(user_input: str) -> str:
    """
    Convert arbitrary user input into a Base32 secret in the same way as Proton:
    - If the input (ignoring whitespace) is valid Base32, use it as-is
      (uppercased, no internal spaces, and strip '=' padding).
    - Otherwise, treat the ORIGINAL input bytes (after stripping only leading/trailing
      whitespace) as the secret and Base32-encode those bytes (no '=' padding).

    Important: DO NOT uppercase or otherwise mutate non-Base32 input before encoding,
    or you will change its bytes and produce different TOTPs than Proton.
    """
    # Keep original bytes except for leading/trailing whitespace
    s = user_input.strip()

    # Check if it's already Base32 (ignoring whitespace/case)
    cleaned = re.sub(r"\s+", "", s)
    if is_valid_base32(cleaned):
        return normalize_base32(cleaned).rstrip("=")

    # Not Base32 → encode original bytes to Base32 (no padding)
    b32 = base64.b32encode(s.encode("utf-8")).decode("ascii")
    return b32.rstrip("=")
