"""Utility module for generating and validating Base32 secrets (Proton manual input compatible)."""
import base64
import re

# Base32 alphabet (uppercase letters + digits 2-7)
_B32_ALPHABET = set("ABCDEFGHIJKLMNOPQRSTUVWXYZ234567")


def is_valid_base32(text: str) -> bool:
    """Return True if `text` can be Base32-decoded (tolerates missing padding and spaces)."""
    if not text or not text.strip():
        return False
    t = normalize_base32(text)
    try:
        base64.b32decode(t + "=" * ((8 - len(t) % 8) % 8))
        return True
    except Exception:
        return False


def normalize_base32(text: str) -> str:
    """Strip whitespace and uppercase only; do NOT change byte meaning."""
    return re.sub(r"\s+", "", text or "").upper().rstrip("=")


def looks_like_base32(s: str) -> bool:
    """True if all chars are from Base32 alphabet."""
    return len(s) > 0 and all(ch in _B32_ALPHABET for ch in s)


def b32_from_utf8(s: str) -> str:
    """Fallback: encode raw UTF-8 bytes into Base32 (no '=' padding)."""
    raw = s.encode("utf-8")
    return base64.b32encode(raw).decode("ascii").rstrip("=")


def as_base32_secret(user_input: str) -> str:
    """
    Proton manual input rules:
      1) If input looks like Base32 AND length >= 16 → treat as Base32.
      2) Otherwise → treat the raw text as UTF-8 bytes and Base32-encode it.
    Returns Base32 without '=' padding.
    """
    s = (user_input or "").strip()
    t = normalize_base32(s)

    # Case 1: "long enough" Base32-like input
    if looks_like_base32(t) and len(t) >= 16:
        try:
            base64.b32decode(t + "=" * ((8 - len(t) % 8) % 8))
            return t  # already normalized
        except Exception:
            pass  # fall through to UTF-8 fallback

    # Case 2: everything else → UTF-8 fallback
    return b32_from_utf8(s)
