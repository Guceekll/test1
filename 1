import streamlit as st
import os
from code_shared import local_css, CSS_PATH, render_sidebar

CODE_FILE = "./code.txt"

def save_code(name, key, countdown_time):
    if not os.path.exists(CODE_FILE):
        with open(CODE_FILE, "w", encoding="utf-8") as f:
            f.write("name,key,time\n")

    with open(CODE_FILE, "r", encoding="utf-8") as f:
        lines = f.readlines()

    existing_names = [line.split(",")[0].strip().lower() for line in lines[1:]]
    if name.lower() in existing_names:
        st.error(f"Code with name '{name}' already exists!")
        return False

    with open(CODE_FILE, "a", encoding="utf-8") as f:
        f.write(f"{name},{key},{int(countdown_time)}\n")

    st.success(f"Code '{name}' added successfully!")
    return True

def main():
    st.set_page_config(page_title="➕ Add Code", page_icon="➕", layout="wide")
    local_css(CSS_PATH)
    render_sidebar("sub")

    st.title("➕ Add New Code")

    name = st.text_input("Code Name", placeholder="e.g., TKL")
    key = st.text_input("Secret Key", placeholder="e.g., 111")
    countdown_time = st.number_input(
        "Countdown Time (seconds)", min_value=15, max_value=60, step=5, value=30
    )

    save_button = st.button("Save Code")

    if save_button:
        if name and key and countdown_time:
            if save_code(name.strip(), key.strip(), countdown_time):
                st.switch_page("app.py")
        else:
            st.warning("Please fill in all fields before saving.")

if __name__ == "__main__":
    main()
