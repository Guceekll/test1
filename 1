import streamlit as st
import time
from code_shared import (
    local_css, render_code_card, CSS_PATH,
    load_code_from_file, render_sidebar
)

st.set_page_config(page_title="🔍 Search Code", page_icon="🔍", layout="wide")

def _init_state():
    st.session_state.setdefault("search_term", "")
    st.session_state.setdefault("search_mode", False)

def _submit_search():
    term = st.session_state.get("search_input", "").strip()
    st.session_state["search_term"] = term
    st.session_state["search_mode"] = bool(term)

def main():
    _init_state()
    local_css(CSS_PATH)
    render_sidebar("sub")

    st.title("🔍 Search Code")
    st.markdown("### Search by name")

    c1, c2 = st.columns([3, 1], gap="small")
    with c1:
        st.text_input(
            "Enter code label",
            key="search_input",
            placeholder="e.g., Google",
            label_visibility="collapsed",
        )
    with c2:
        if st.button("Search", use_container_width=True):
            _submit_search()

    if not st.session_state.get("search_input", "").strip():
        st.session_state["search_term"] = ""
        st.session_state["search_mode"] = False

    code = st.session_state.get("code") or load_code_from_file()
    current_time = int(time.time())

    if st.session_state["search_mode"] and st.session_state["search_term"]:
        term = st.session_state["search_term"].lower()
        matching = {k: v for k, v in code.items() if k.lower() == term}
        if matching:
            label, code_data = list(matching.items())[0]
            render_code_card(label, code_data, current_time, full_width=True)
        else:
            st.info("No code found with that label.")

    time.sleep(1)
    st.rerun()

if __name__ == "__main__":
    main()
