"""Streamlit home page displaying all two-factor codes with auto-refresh."""
import streamlit as st
import time
from code_shared import (
    local_css, load_code_from_file,
    render_code_card, CSS_PATH, render_sidebar
)


# ==== Page Entrypoint ====
def main() -> None:
    """Render the main authenticator grid and refresh every second."""
    # Global UI setup
    local_css(CSS_PATH)
    render_sidebar("home")

    st.set_page_config(page_title="Two-Factor Authenticator", layout="wide")
    st.title("🔐 Two-Factor Authenticator")

    # Load code data and persist in session for reuse
    code = load_code_from_file()
    st.session_state["code"] = code
    current_time = int(time.time())

    # Render code cards in a 3-column grid
    if code:
        cols = st.columns(3)
        col = 0
        for label, code_data in code.items():
            with cols[col]:
                render_code_card(label, code_data, current_time)
            col = (col + 1) % 3
    else:
        st.info("No code found. Please add one.")

    # Auto-refresh every second for live countdown display
    time.sleep(1)
    st.rerun()


if __name__ == "__main__":
    main()
