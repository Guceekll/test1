"""Shared helpers for the Streamlit 2FA app: CSS loading, file I/O, TOTP rendering, and sidebar."""
import os
import time
import hashlib
import streamlit as st
import pyotp
from typing import Optional
from base32_converter import as_base32_secret  # <-- key normalization exactly like Proton

CSS_PATH = "style.css"
CODE_FILE = "code.txt"

# —— Proton Authenticator compatibility ——
# RFC 6238 defaults, which Proton also uses for typical TOTP entries.
TOTP_DIGITS = 6
TOTP_DIGEST = hashlib.sha1  # Do not change unless you confirm a non-standard setup.


# ==== Styles ====
def local_css(file_name: str) -> None:
    """Inject a local CSS file into the page if present."""
    if os.path.exists(file_name):
        with open(file_name, "r", encoding="utf-8") as f:
            st.markdown(f"<style>{f.read()}</style>", unsafe_allow_html=True)


# ==== Data Loading ====
def load_code_from_file() -> dict:
    """
    Load codes from CSV-like text 'code.txt' and return:
      { name: {'secret': str, 'countdown_time': int} }

    File format (header line is expected):
      name,key,period[,memo]
    - 'memo' column may exist but is not used here.
    - If 'period' is missing/invalid, fallback to 30 seconds.
    """
    code = {}
    if not os.path.exists(CODE_FILE):
        return code

    with open(CODE_FILE, "r", encoding="utf-8") as f:
        # Skip header line if present
        try:
            next(f)
        except StopIteration:
            return code

        for raw in f:
            if not raw.strip():
                continue
            parts = [p.strip() for p in raw.strip().split(",")]
            # Accept 3 or 4 columns (memo ignored if present)
            if len(parts) < 3:
                continue

            name, key, time_interval = parts[0], parts[1], parts[2]
            try:
                interval = int(time_interval)
            except Exception:
                interval = 30  # no TOTP_PERIOD_DEFAULT; safe fallback

            code[name] = {"secret": key, "countdown_time": interval}

    return code


# ==== TOTP Helpers ====
def get_default_code_state(current_time: int, countdown_time: int) -> dict:
    """Return a neutral TOTP display block for error/fallback cases."""
    return {
        "period": current_time - (current_time % countdown_time),
        "current": "000000",
        "next": "000000",
    }


def generate_code(secret: str, countdown_time: int, current_time: int, force_default: bool = False) -> dict:
    """
    Compute current/next TOTP values using Proton-compatible secret handling.

    Behavior:
    - If `secret` looks like Base32 (ignoring whitespace), use it as Base32 (uppercased, no padding).
    - Otherwise, Base32-encode the ORIGINAL bytes of the input (after stripping only leading/trailing
      whitespace), *without* changing case or internal content. (Matches Proton.)
    """
    try:
        if force_default:
            return get_default_code_state(current_time, countdown_time)

        # Convert user input to a proper Base32 secret in the exact same way Proton does.
        base32_secret = as_base32_secret(secret)

        # Standard RFC 6238 TOTP parameters
        totp = pyotp.TOTP(
            base32_secret,
            interval=countdown_time,
            digits=TOTP_DIGITS,
            digest=TOTP_DIGEST,
        )

        period_start = current_time - (current_time % countdown_time)
        return {
            "period": period_start,
            "current": totp.at(current_time),
            "next": totp.at(period_start + countdown_time),
        }
    except Exception as e:
        # Keep UI responsive even if a single entry fails
        print(f"TOTP error for secret='{secret}': {e}")
        return get_default_code_state(current_time, countdown_time)


def calculate_remaining_time(countdown_time: int, current_time: Optional[int] = None) -> int:
    """Return remaining seconds in the current TOTP period."""
    if current_time is None:
        current_time = int(time.time())
    period_start = current_time - (current_time % countdown_time)
    return countdown_time - (current_time - period_start)


# ==== UI Rendering ====
def render_code_card(label: str, code_data: dict, current_time: int, full_width: bool = False) -> None:
    """Render a single code tile with circular time-progress."""
    remaining_time = calculate_remaining_time(code_data["countdown_time"], current_time)
    code = generate_code(code_data["secret"], code_data["countdown_time"], current_time)
    degrees = (remaining_time / code_data["countdown_time"]) * 360
    progress_color = "#4CAF50" if remaining_time > 5 else "#FF5722"

    card_html = f"""
    <div class="stContainer" style="{'width: 100%;' if full_width else ''}">
        <div class="code-header"><div class="code-label">{label}</div></div>
        <div class="code-value">{code['current']}</div>
        <div class="circular-progress">
            <div class="circular-progress-bar"
                 style="background: conic-gradient({progress_color} {degrees}deg, #e0e0e0 {degrees}deg)"></div>
            <div class="circular-progress-text">{remaining_time}</div>
        </div>
        <div class="code-next">Next: {code['next']}</div>
    </div>
    """
    if full_width:
        st.columns(1)[0].markdown(card_html, unsafe_allow_html=True)
    else:
        st.markdown(card_html, unsafe_allow_html=True)


# ==== Sidebar ====
def _sidebar_user_box() -> None:
    """Render a small user panel in the sidebar."""
    user = st.session_state.get("user", {})
    name = user.get("name", "Guest")
    avatar_emoji = user.get("avatar_emoji", "👤")

    st.markdown(
        f"""
        <div class="user-box">
            <div class="user-avatar">{avatar_emoji}</div>
            <div class="user-name"><strong>{name}</strong></div>
        </div>
        """,
        unsafe_allow_html=True,
    )


def render_sidebar(current: str) -> None:
    """Render left navigation; emphasize the current page."""
    with st.sidebar:
        _sidebar_user_box()
        st.markdown("---")
        if current == "home":
            st.page_link("app.py",               label="🏠 Home")
            st.page_link("pages/search.py",      label="🔎 Search Code")
            st.page_link("pages/add_code.py",    label="➕ Add New Code")
            st.page_link("pages/edit_code.py",   label="✏️ Edit Code")
            st.page_link("pages/recycle_bin.py", label="🗑️ Recycle bin")
        else:
            st.page_link("app.py",               label="🏠 Back to Home")
