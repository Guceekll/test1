# main.py
from .workflow import build_workflow
from .nodes import (
    generate_query, collect_info_qvics,
    evaluate_info, refine_info,
    generate_report, optimizer
)
from .state import TroubleState

if __name__ == "__main__":
    user_input = input("あなたの知りたいことを入力してね〜🧠：")
    state = {"user_input": user_input}

    state = generate_query(state)
    print("[検索クエリ生成]\n", state.get("query", ""))

    state = collect_info_qvics(state)
    print("[情報収集_QVICS]\n", state.get("info_qvics", []))

    state = evaluate_info(state)
    print("[情報評価]\n", state.get("evaluate_info", ""))

    state = refine_info(state)
    print("[情報精選]\n", state.get("refine_info", ""))

    state = generate_report(state)
    print("[回答生成]\n", state.get("report", ""))

    state = optimizer(state)
    print("[回答評価]\n", state.get("optimizer_decision", ""))
